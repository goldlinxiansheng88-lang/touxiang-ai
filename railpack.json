{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "build": {
      "commands": [
        "cd backend",
        "python -m pip install -r requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port $PORT"
  }
}

