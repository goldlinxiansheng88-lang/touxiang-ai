# 仓库根可选 .env（会与 backend/.env 合并加载，backend/.env 优先）。
# 数据库与 Redis：填写云或其它可访问实例的连接串 —— 详见 backend/.env.example。

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@db.example.supabase.co:5432/postgres
REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379

# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

ADMIN_EMAIL=admin@aurashift.ai
ADMIN_PASSWORD=changeme

PUBLIC_BASE_URL=http://localhost:8000

CLAUDE_API_KEY=
IMAGE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 可选：收款方式也可在管理后台「支付与会员」中配置（入库），不必写在此处。
# Creem：Webhook 回调填 {PUBLIC_BASE_URL}/api/webhooks/creem
# Lemon Squeezy：Webhook 回调填 {PUBLIC_BASE_URL}/api/webhooks/lemon-squeezy
# USDT：配置收款地址后，链上到账需在后台「订单」中手动「确认收款」。
